{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/media/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/dorfmovies/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Outfit))/i]",
        "message": "Font not provided by the design system. Available: Outfit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:violet|orange|rose|emerald|amber|neutral)$/]",
        "message": "<Badge> tone must be one of 'violet' | 'orange' | 'rose' | 'emerald' | 'amber' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|disabled|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, disabled, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|accent|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'accent' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:violet|orange|rose|neutral)$/]",
        "message": "<Eyebrow> tone must be one of 'violet' | 'orange' | 'rose' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:glow|interactive|padding|children|key|ref|className|style|children)$/]",
        "message": "<GlassCard> doesn't accept that prop. Declared props: glow, interactive, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:violet|rose|orange|none)$/]",
        "message": "<GlassCard> glow must be one of 'violet' | 'rose' | 'orange' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|size|hover|glow|key|ref|className|style|children)$/]",
        "message": "<IconChip> doesn't accept that prop. Declared props: icon, tone, size, hover, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:violet|orange|rose|emerald)$/]",
        "message": "<IconChip> tone must be one of 'violet' | 'orange' | 'rose' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|multiline|rows|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, multiline, rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MediaRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|year|type|posterUrl|rating|onRate|review|watchedAt|tmdbRating|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MediaRow> doesn't accept that prop. Declared props: title, year, type, posterUrl, rating, onRate, review, watchedAt, tmdbRating, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MediaRow'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:movie|show)$/]",
        "message": "<MediaRow> type must be one of 'movie' | 'show'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, label, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='PosterCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|year|posterUrl|rating|overlay|width|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PosterCard> doesn't accept that prop. Declared props: title, year, posterUrl, rating, overlay, width, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotlightCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:spotlightColor|padding|children|key|ref|className|style|children)$/]",
        "message": "<SpotlightCard> doesn't accept that prop. Declared props: spotlightColor, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|readOnly|size|showValue|style|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, onChange, readOnly, size, showValue, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|tone|tag|caption|captionIcon|hover|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: value, label, icon, tone, tag, caption, captionIcon, hover."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:violet|orange|rose|white)$/]",
        "message": "<StatTile> tone must be one of 'violet' | 'orange' | 'rose' | 'white'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
